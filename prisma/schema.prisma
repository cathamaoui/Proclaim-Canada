// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation("accounts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String       @id @default(cuid())
  email         String?      @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  role          UserRole     @default(PREACHER)
  phone         String?
  bio           String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Password Reset
  resetToken    String?      @unique
  resetExpires  DateTime?

  // Admin Fields
  isAdmin       Boolean      @default(false)
  isBanned      Boolean      @default(false)
  bannedReason  String?      @db.Text
  bannedUntil   DateTime?

  accounts             Account[]       @relation("accounts")
  sessions             Session[]
  preacherProfile      PreacherProfile?
  churchProfile        ChurchProfile?
  availabilitySlots    AvailabilitySlot[]
  churchListings       ChurchListing[]
  applications         Application[]
  sentMessages         Message[] @relation("sentBy")
  receivedMessages     Message[] @relation("receivedBy")
  givenRatings         Rating[] @relation("ratedBy")
  receivedRatings      Rating[] @relation("ratedTo")

  @@index([email])
  @@index([isAdmin])
  @@index([isBanned])
}

enum UserRole {
  PREACHER
  CHURCH
  ADMIN
}

model PreacherProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  denomination    String?
  specialization  String?
  yearsOfExperience Int    @default(0)
  hourlyRate      Decimal? @db.Decimal(10, 2)
  bio             String?  @db.Text
  verified        Boolean  @default(false)
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  totalRatings    Int      @default(0)
  averageResponseTime Int? // in hours
  acceptanceRate  Decimal  @default(0) @db.Decimal(5, 2) // percentage
  serviceTypes    String[] @default([])
  customService   String?
  
  // Photo and Media
  profilePhotoUrl String?
  resumeUrl       String?
  elevatorPitchUrl String? // Audio recording URL
  sermonVideoUrl  String?  // Sample sermon video
  worshipVideoUrl String?  // Sample worship/music video
  
  // Theology & Beliefs
  theologyStatement String? @db.Text // Beliefs, theology statement
  preferredDenominations String[] @default([]) // Multiple denominations they work with
  
  // Availability & Location
  availability    String[] @default([]) // e.g., ["weekends", "summer", "flexible"]
  travelRadiusKm  Int?     // How far willing to travel
  
  // Affiliation & Credentials
  churchAffiliation String?
  ordinationStatus String? // "ordained", "licensed", "commissioned", "student", "none"
  backgroundCheckStatus String? // "verified", "pending", "not-completed"
  
  // Professional Info
  website         String?
  socialMediaLinks Json? // { linkedin: "", youtube: "", twitter: "" }
  specializations String[] @default([]) // e.g., ["children", "youth", "worship", "teaching"]
  otherSpecializations String?
  trainingEducation String? @db.Text // Education history
  preferredTopics String[] @default([]) // e.g., ["evangelism", "discipleship"]
  numSpeakingEngagements Int @default(0)
  speakingFeeRange String? // e.g., "0-100", "100-250", "250+"
  
  // References
  references      Json? // [{ name: "", title: "", email: "", phone: "" }]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificates     String[]
  languages        String[]

  @@index([userId])
  @@index([rating])
  @@index([verified])
}

model ChurchProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  churchName      String?
  organizationName String?
  denomination    String?
  specifyAffiliation String?
  country         String?
  street          String?
  address         String?
  city            String?
  province        String?
  postalCode      String?
  phone           String?
  website         String?
  averageAttendance String?
  founded         Int?
  bio             String?  @db.Text
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  totalRatings    Int      @default(0)
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription     Subscription?

  @@index([userId])
  @@index([city])
  @@index([province])
  @@index([rating])
  @@index([verified])
}

model Subscription {
  id                      String   @id @default(cuid())
  churchProfileId         String   @unique
  planType                PlanType @default(TRIAL)
  status                  SubscriptionStatus @default(ACTIVE)
  stripeCustomerId        String?  @unique
  stripeSubscriptionId    String?  @unique
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  postingsRemaining       Int?     // null = unlimited
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  cancelledAt             DateTime?

  churchProfile           ChurchProfile @relation(fields: [churchProfileId], references: [id], onDelete: Cascade)

  @@index([churchProfileId])
  @@index([status])
  @@index([planType])
  @@index([currentPeriodEnd])
}

enum PlanType {
  TRIAL
  IMMEDIATE_CALL
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS
  SIX_MONTHS
  UNLIMITED_YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model AvailabilitySlot {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime
  startTime           String
  endTime             String
  available           Boolean  @default(true)
  bookings            Int      @default(0)
  notes               String?  @db.Text
  willingToTravel     Boolean  @default(false)
  travelDistance      Int?     // in km
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model ChurchListing {
  id              String   @id @default(cuid())
  createdBy       String
  title           String
  description     String   @db.Text
  type            ListingType
  date            DateTime
  location        String
  compensation    String?
  status          ListingStatus @default(OPEN)
  
  // Church Identity Section
  churchName      String?
  contactName     String?
  denomination    String?
  congregationProfile String? @db.Text
  avgAttendance   Int?
  neighborhood    String?
  
  // Theological & Liturgical Standards Section
  statementOfFaithUrl String?
  preferredBibleTranslation String?
  preachingStyleSought String? @db.Text
  dresscode       String?
  
  // Service Logistics Section
  arrivalTime     String?
  sermonLength    Int?
  additionalDuties String? @db.Text
  technologyAvailable String? @db.Text
  technologyRequired String? @db.Text
  
  // Compensation & Hospitality Section
  honorarium      String?
  mileageReimbursement String?
  travelLodging   String? @db.Text
  meals           String? @db.Text
  
  // Applicant Requirements Section
  necessaryDocuments String? @db.Text
  backgroundCheckRequired String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  applications    Application[]
  customQuestions ApplicationQuestion[]

  @@index([createdBy])
  @@index([date])
  @@index([status])
}

enum ListingType {
  SERMON
  SPECIAL_SERVICE
  REVIVAL
  WORKSHOP
  OTHER
}

enum ListingStatus {
  OPEN
  IN_PROGRESS
  FILLED
  CANCELLED
}

model Application {
  id          String   @id @default(cuid())
  listingId   String
  applicantId String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?  @db.Text
  appliedAt   DateTime @default(now())
  respondedAt DateTime?
  updatedAt   DateTime @updatedAt

  listing     ChurchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicant   User          @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  answers     ApplicationAnswer[]

  @@unique([listingId, applicantId])
  @@index([listingId])
  @@index([applicantId])
  @@index([status])
}

model ApplicationQuestion {
  id          String   @id @default(cuid())
  listingId   String
  questionText String  @db.Text
  questionType String  // "text", "textarea", "radio", "checkbox", "file"
  options     String[]? // For radio/checkbox questions
  required    Boolean @default(true)
  order       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing     ChurchListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  answers     ApplicationAnswer[]

  @@index([listingId])
}

model ApplicationAnswer {
  id          String   @id @default(cuid())
  applicationId String
  questionId  String
  answerText  String?  @db.Text // Text/textarea answer
  answerFile  String?  // File URL
  answerOptions String[]? // Selected options for radio/checkbox
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    ApplicationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionId])
  @@index([applicationId])
  @@index([questionId])
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  content     String   @db.Text
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Conversation grouping
  conversationId String?
  subject     String?
  isArchived  Boolean  @default(false)

  sender      User     @relation("sentBy", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User     @relation("receivedBy", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([read])
  @@index([conversationId])
}

model Rating {
  id          String   @id @default(cuid())
  ratedById   String
  ratedToId   String
  relatedTo   RatingType  // APPLICATION, LISTING, etc
  relatedId   String?     // ID of application or listing
  rating      Int         // 1-5 stars
  comment     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ratedBy     User     @relation("ratedBy", fields: [ratedById], references: [id], onDelete: Cascade)
  ratedTo     User     @relation("ratedTo", fields: [ratedToId], references: [id], onDelete: Cascade)

  @@unique([ratedById, ratedToId, relatedId, relatedTo])
  @@index([ratedById])
  @@index([ratedToId])
  @@index([rating])
  @@index([createdAt])
}

enum RatingType {
  APPLICATION
  LISTING
  GENERAL
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  email      String
  token      String   @unique
  expires    DateTime

  @@unique([email, token])
  @@index([email])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  message     String   @db.Text
  relatedId   String?  // ID of related object (message, application, etc)
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([read])
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  MESSAGE_RECEIVED
  LISTING_VIEWED
  RATING_RECEIVED
  SYSTEM_ALERT
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  resource    String   // User, Listing, Application, etc
  resourceId  String?
  changes     String?  @db.Text // JSON of what changed
  ipAddress   String?
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
}
